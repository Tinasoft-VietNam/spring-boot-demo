                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    var payload = pm.response.json();",
                                    "    var token = payload?.data?.token || payload?.data;",
                                    "    if (token) {",
                                    "        pm.environment.set('adminAccessToken', token);",
                                    "    }",
                                    "    console.log('✓ Token refreshed');",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{adminRefreshToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/refresh-token",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "auth", "refresh-token"]
                        }
                    }
